# Server
PORT=8080
# Local dev: http://localhost:5173
# Production: https://cube.nebulouscode.com
FRONTEND_URL=http://localhost:5173

# Database (Neon connection string)
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME

# Auth
JWT_SECRET=change-me-to-a-256-bit-random
ARGON2_M_KIB=19456
ARGON2_T=2
ARGON2_P=1

# Email (Resend)
# Verified sending subdomain is mail.nebulouscode.com.
# For very early dev before DNS verification finishes you can use Resend's sandbox
# sender (onboarding@resend.dev) — only delivers to your Resend account email.
RESEND_API_KEY=re_your_key
EMAIL_FROM="OLL Practice <noreply@mail.nebulouscode.com>"

# reCAPTCHA v3
RECAPTCHA_SECRET_KEY=your-recaptcha-secret
RECAPTCHA_MIN_SCORE=0.5

# Logging
RUST_LOG=info,oll_backend=debug
