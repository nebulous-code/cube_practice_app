# Server
PORT=8080
# Local dev: http://localhost:5173
# Production: https://cube.nebulouscode.com
FRONTEND_URL=http://localhost:5173

# Database (Neon connection string)
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME

# Auth
JWT_SECRET=change-me-to-a-256-bit-random
ARGON2_M_KIB=19456
ARGON2_T=2
ARGON2_P=1

# Email (Resend)
# Verified sending subdomain is mail.nebulouscode.com.
# For very early dev before DNS verification finishes you can use Resend's sandbox
# sender (onboarding@resend.dev) — only delivers to your Resend account email.
RESEND_API_KEY=re_your_key
EMAIL_FROM="Cube Practice <noreply@mail.nebulouscode.com>"

# reCAPTCHA v3
RECAPTCHA_SECRET_KEY=your-recaptcha-secret
RECAPTCHA_MIN_SCORE=0.5

# Logging
RUST_LOG=info,cube_backend=debug

# Integration tests (cargo test)
# Required for tests in `backend/tests/`. Each test creates a fresh randomly-
# named database, runs migrations, and drops it on completion. Point at a
# local Postgres with CREATEDB privileges — NEVER your production DB.
# Distinct from DATABASE_URL on purpose: refusing to fall back means a
# misconfigured run can't accidentally drop production tables.
# Local Docker example:
#   docker run --rm -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
